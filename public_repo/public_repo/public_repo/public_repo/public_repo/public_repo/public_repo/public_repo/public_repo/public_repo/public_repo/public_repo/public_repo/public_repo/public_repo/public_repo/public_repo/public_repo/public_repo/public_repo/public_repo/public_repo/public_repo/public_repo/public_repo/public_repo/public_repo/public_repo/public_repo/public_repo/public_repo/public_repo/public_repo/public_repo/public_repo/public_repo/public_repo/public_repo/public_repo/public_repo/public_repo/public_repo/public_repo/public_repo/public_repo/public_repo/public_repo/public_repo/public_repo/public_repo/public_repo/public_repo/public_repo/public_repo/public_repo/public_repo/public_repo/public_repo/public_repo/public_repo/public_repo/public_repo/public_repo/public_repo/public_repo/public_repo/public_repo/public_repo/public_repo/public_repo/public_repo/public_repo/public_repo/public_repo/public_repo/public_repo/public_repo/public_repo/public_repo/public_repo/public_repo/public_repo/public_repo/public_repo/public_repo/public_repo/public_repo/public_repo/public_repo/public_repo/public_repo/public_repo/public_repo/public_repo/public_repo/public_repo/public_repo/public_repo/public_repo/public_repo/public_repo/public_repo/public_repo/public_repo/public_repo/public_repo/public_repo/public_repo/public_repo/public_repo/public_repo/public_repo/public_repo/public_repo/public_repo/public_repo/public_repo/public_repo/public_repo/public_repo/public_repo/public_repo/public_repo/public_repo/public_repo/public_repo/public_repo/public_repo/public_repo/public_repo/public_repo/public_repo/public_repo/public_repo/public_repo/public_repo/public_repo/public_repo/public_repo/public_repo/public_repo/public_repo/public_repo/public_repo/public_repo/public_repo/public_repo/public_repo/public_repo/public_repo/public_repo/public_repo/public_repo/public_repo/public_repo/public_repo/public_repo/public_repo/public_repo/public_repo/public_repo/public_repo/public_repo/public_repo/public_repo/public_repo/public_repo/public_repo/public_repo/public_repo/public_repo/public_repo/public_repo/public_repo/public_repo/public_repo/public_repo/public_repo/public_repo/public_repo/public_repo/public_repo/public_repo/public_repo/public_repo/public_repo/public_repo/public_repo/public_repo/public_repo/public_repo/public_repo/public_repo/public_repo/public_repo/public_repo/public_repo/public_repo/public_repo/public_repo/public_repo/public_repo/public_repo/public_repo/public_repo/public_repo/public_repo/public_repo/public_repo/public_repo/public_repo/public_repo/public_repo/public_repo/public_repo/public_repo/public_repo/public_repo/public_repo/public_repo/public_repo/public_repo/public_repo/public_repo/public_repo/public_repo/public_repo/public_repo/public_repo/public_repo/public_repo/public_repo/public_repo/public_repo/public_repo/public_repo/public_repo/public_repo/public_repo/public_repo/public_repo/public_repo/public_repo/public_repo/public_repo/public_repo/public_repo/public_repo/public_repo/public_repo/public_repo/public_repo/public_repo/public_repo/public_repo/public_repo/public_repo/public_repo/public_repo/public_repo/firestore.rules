rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "uniniconn@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isSystemEmpty() {
      return !exists(/databases/$(database)/documents/config/stats);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidQuestion(data) {
      return data.id is string &&
             (data.imageUrl == null || data.imageUrl is string) &&
             (data.field is string || data.field is list) &&
             data.source is string &&
             data.difficulty is list &&
             data.type is string &&
             data.createdBy is string &&
             data.createdAt is string &&
             data.content is string &&
             (!('creatorStudentId' in data) || data.creatorStudentId is string) &&
             (!('publicTags' in data) || data.publicTags is list);
    }

    function isValidKnowledgePoint(data) {
      return data.userId == request.auth.uid &&
             data.id is string &&
             data.questionId is string &&
             data.field is string &&
             data.title is string &&
             data.content is string &&
             data.level is number &&
             data.mastered is bool &&
             data.createdAt is string;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin() || isSystemEmpty());
      allow update: if isAuthenticated() && (
        isAdmin() || 
        isOwner(userId) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points']) && request.resource.data.points > resource.data.points)
      ) && 
      (resource.data.studentId == '1357924680' ? request.resource.data.role == 'admin' : true) &&
      (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'studentId', 'createdAt']) || isAdmin());
      allow delete: if isAdmin() && resource.data.studentId != '1357924680';
    }

    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidQuestion(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.createdBy == request.auth.uid && isValidQuestion(request.resource.data) && request.resource.data.createdBy == resource.data.createdBy && request.resource.data.id == resource.data.id) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['publicTags']) && request.resource.data.publicTags.hasAll(resource.data.publicTags))
      );
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }

    match /allowedStudents/{studentId} {
      allow read: if isAuthenticated();
      allow write: if (isAdmin() || isSystemEmpty()) && studentId != '1357924680';
    }

    match /userTags/{tagId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && (isAdmin() || isSystemEmpty());
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /knowledgePoints/{kpId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidKnowledgePoint(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidKnowledgePoint(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
